<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF7FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingTop="76dp"
        android:paddingEnd="28dp"
        android:paddingBottom="40dp">

        <ImageView
            android:id="@+id/imgPoster"
            android:layout_width="170dp"
            android:layout_height="245dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="28dp"
            android:adjustViewBounds="true"
            android:background="#F2EAF5"
            android:clipToOutline="true"
            android:contentDescription="Poster de película"
            android:elevation="4dp"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp"
            android:gravity="center"
            android:text="Título"
            android:textColor="#25212A"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDirector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Director"
            android:textColor="#3D3542"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/txtNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="38dp"
            android:gravity="start"
            android:lineSpacingExtra="4dp"
            android:text="Notas"
            android:textColor="#4A414F"
            android:textSize="17sp" />

        <Button
            android:id="@+id/btnImdb"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="#6B50A8"
            android:text="Ver en IMDb"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnMap"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:backgroundTint="#6B50A8"
            android:text="Ver lugar de rodaje en mapa"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>