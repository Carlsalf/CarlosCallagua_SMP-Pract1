<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:padding="8dp"
    android:layout_width="match_parent"
    android:layout_height="72dp">

    <ImageView
        android:id="@+id/imgPosterItem"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        android:layout_alignParentStart="true"
        android:contentDescription="@string/desc_poster"
        android:src="@mipmap/ic_launcher" />

    <TextView
        android:id="@+id/txtTitleItem"
        android:layout_toEndOf="@id/imgPosterItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textStyle="bold"
        android:textSize="16sp"
        android:text="Título" />

    <TextView
        android:id="@+id/txtDirectorItem"
        android:layout_below="@id/txtTitleItem"
        android:layout_toEndOf="@id/imgPosterItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textSize="14sp"
        android:text="Director" />
</RelativeLayout>
